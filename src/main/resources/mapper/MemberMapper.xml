<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.lucky.luckyproject.mapper.MemberMapper">

    <resultMap id="MemberResultMap" type="com.lucky.luckyproject.domain.Member">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="email" column="email"/>
        <result property="password" column="password"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <insert id="save" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO member (name, email, password, created_at)
        VALUES (#{name}, #{email}, #{password}, NOW())
    </insert>

    <select id="findByEmail" resultMap="MemberResultMap">
        SELECT id, name, email, password, created_at
        FROM member
        WHERE email = #{email}
    </select>

</mapper>
